# OPENAI_MODEL=llama3.1-70b

# --- Together AI ---
# OPENAI_BASE_URL=https://api.together.xyz/v1
# OPENAI_API_KEY=YOUR_KEY
# OPENAI_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo
# OPENAI_SMALL_FAST_MODEL=meta-llama/Llama-3.2-3B-Instruct-Turbo

# --- Fireworks AI ---
# OPENAI_BASE_URL=https://api.fireworks.ai/inference/v1
# OPENAI_API_KEY=fw_YOUR_KEY
# OPENAI_MODEL=accounts/fireworks/models/deepseek-r1

# --- Perplexity ---
# OPENAI_BASE_URL=https://api.perplexity.ai
# OPENAI_API_KEY=pplx-YOUR_KEY
# OPENAI_MODEL=llama-3.1-sonar-large-128k-online

# --- Azure OpenAI ---
# AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com
# AZURE_OPENAI_API_KEY=YOUR_KEY
# AZURE_OPENAI_API_VERSION=2024-08-01-preview
# OPENAI_MODEL=gpt-4.1              # must match your Azure deployment name

# --- Ollama (local) ---
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_API_KEY=ollama
# OPENAI_MODEL=llama3.1:70b
# OPENAI_SMALL_FAST_MODEL=llama3.2:3b
# MODEL_NO_PARALLEL_TOOLS=1         # enable if tools cause errors

# --- vLLM (local) ---
# OPENAI_BASE_URL=http://localhost:8000/v1
# OPENAI_API_KEY=vllm
# OPENAI_MODEL=meta-llama/Llama-3.1-70B-Instruct

# --- LM Studio (local) ---
# OPENAI_BASE_URL=http://localhost:1234/v1
# OPENAI_API_KEY=lmstudio
# OPENAI_MODEL=local-model

# --- WatsonX (via LiteLLM proxy) ---
# Run first: pip install 'litellm[proxy]' && litellm --model watsonx/ibm/granite-20b-code-instruct --port 4000
# OPENAI_BASE_URL=http://localhost:4000/v1
# OPENAI_API_KEY=anything
# OPENAI_MODEL=watsonx/ibm/granite-20b-code-instruct
# WATSONX_API_KEY=YOUR_KEY
# WATSONX_URL=https://us-south.ml.cloud.ibm.com
# WATSONX_PROJECT_ID=YOUR_PROJECT_ID

# --- AWS Bedrock (via LiteLLM proxy) ---
# Run first: litellm --model bedrock/amazon.nova-pro-v1:0 --port 4000
# OPENAI_BASE_URL=http://localhost:4000/v1
# OPENAI_API_KEY=anything
# OPENAI_MODEL=bedrock/amazon.nova-pro-v1:0
# AWS_ACCESS_KEY_ID=YOUR_KEY
# AWS_SECRET_ACCESS_KEY=YOUR_SECRET
# AWS_REGION_NAME=us-east-1

# --- Cohere (via LiteLLM proxy) ---
# Run first: litellm --model cohere/command-r-plus --port 4000
# OPENAI_BASE_URL=http://localhost:4000/v1
# OPENAI_API_KEY=anything
# OPENAI_MODEL=cohere/command-r-plus
# COHERE_API_KEY=YOUR_KEY

# =============================================================================
# MODEL SELECTION (optional — defaults shown)
# =============================================================================
OPENAI_MODEL=gpt-4.1
OPENAI_SMALL_FAST_MODEL=gpt-4.1-mini

# =============================================================================
# REASONING MODEL SETTINGS
# Only relevant for o1, o3, o4-mini, or custom reasoning models
# =============================================================================
# REASONING_EFFORT=high             # low | medium | high (default: high)
# MODEL_IS_REASONING=1              # Force reasoning mode for any model name
# MODEL_NO_STREAMING=1              # Force non-streaming (auto for o1)
# MODEL_NO_TOOLS=1                  # Disable tool use (auto for o1-mini)
# MODEL_NO_PARALLEL_TOOLS=1         # Disable parallel tools (auto for Gemini/Mistral/Llama)
# MODEL_TEMPERATURE=0.7             # Set temperature (omit for reasoning models)

# =============================================================================
# MODEL CONTEXT AND CAPABILITY OVERRIDES
# Use these for models not in our built-in table
# =============================================================================
# MODEL_CONTEXT_WINDOW=200000       # Context window in tokens
# MODEL_MAX_OUTPUT_TOKENS=32768     # Max output tokens
# MODEL_KNOWLEDGE_CUTOFF=2025-01    # Knowledge cutoff date shown to the model
# DISABLE_1M_CONTEXT=1              # Disable 1M context even for supporting models

# =============================================================================
# LOCAL REPORTING (optional)
# If unset, all analytics are silently dropped — app works fine without it
# =============================================================================
# LOCAL_REPORTING_URL=http://localhost:4040
# LOCAL_SESSION_DIR=~/.local-sessions
# LOCAL_METRICS_DIR=~/.local-metrics

# Reporting server settings (set these when running local-reporting-server/server.ts)
# PORT=4040
# DATA_DIR=./data

# =============================================================================
# AGENT IDENTITY (optional)
# =============================================================================
# AGENT_NAME=AI Code Assistant
# PACKAGE_NAME=ai-code-assistant
# AGENT_BASE_URL=
# AGENT_DOCS_URL=

# =============================================================================
# FEATURE FLAGS (optional — set to 1 to enable)
# =============================================================================
# DISABLE_ANALYTICS=0
# FEATURE_REACTIVE_COMPACT=0
# FEATURE_CONTEXT_COLLAPSE=0
# FEATURE_CONNECTOR_TEXT=0
# FEATURE_TENGU_TOOL_PEAR=0

# =============================================================================
# BRIDGE / REMOTE SESSIONS (advanced, disabled by default)
# =============================================================================
# BRIDGE_ENABLED=0
# BRIDGE_SESSION_URL=
# BRIDGE_API_KEY=

# =============================================================================
# MCP REGISTRY (optional)
# =============================================================================
# LOCAL_MCP_REGISTRY_URL=

# =============================================================================
# DEBUGGING (optional)
# =============================================================================
# DEBUG_TO_STDERR=0
# CLAUDE_ENABLE_STREAM_WATCHDOG=0
# CLAUDE_STREAM_IDLE_TIMEOUT_MS=90000
# API_TIMEOUT_MS=600000

# =============================================================================
# CROSS-PLATFORM PATHS (optional)
# =============================================================================
# AGENT_CONFIG_DIR=~/.ai-assistant      # override config dir (default: ~/.ai-assistant)
# CLAUDE_CONFIG_DIR=~/.ai-assistant     # legacy alias for AGENT_CONFIG_DIR
